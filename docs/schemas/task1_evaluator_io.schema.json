{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task1_evaluator_io.schema.json",
  "title": "Task 1 Evaluator Input Output Placeholder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sample_id",
    "inputs",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "sample_id": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_entry",
        "labels_path",
        "metadata_path"
      ],
      "properties": {
        "manifest_entry": {
          "type": "object",
          "description": "One JSON object from task1_rgbd_labels manifest.jsonl."
        },
        "labels_path": {
          "type": "string"
        },
        "metadata_path": {
          "type": "string"
        },
        "thinker_output_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "planner_trace_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "fail",
            "skip",
            null
          ]
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "integer",
              "boolean",
              "string",
              "null"
            ]
          }
        },
        "failure_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "description": "Minimal Phase 2/4 evaluator I/O placeholder. This declares expected data flow only; no evaluator runtime is implemented in Phase 1."
}
